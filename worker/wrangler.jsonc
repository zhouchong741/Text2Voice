{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "text2voice-tts",
  "main": "src/index.js",
  "compatibility_date": "2026-04-25",
  "observability": {
    "enabled": true
  },
  "vars": {
    "ALLOWED_ORIGIN": "*",
    "MAX_TEXT_LENGTH": "300",
    "XUNFEI_TIMEOUT_MS": "15000",
    "XUNFEI_VOICE_CN": "x4_xiaoyan",
    "XUNFEI_VOICE_EN": "x4_xiaoyan"
  }
}
