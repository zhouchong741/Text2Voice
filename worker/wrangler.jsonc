{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "text2voice-tts",
  "main": "src/index.js",
  "compatibility_date": "2026-04-25",
  "observability": {
    "enabled": true
  },
  "vars": {
    "ALLOWED_ORIGIN": "*",
    "MAX_TEXT_LENGTH": "300",
    "AZURE_SPEECH_REGION": "eastus",
    "AZURE_OUTPUT_FORMAT": "audio-24khz-48kbitrate-mono-mp3",
    "AZURE_VOICE_CN": "zh-CN-XiaoxiaoNeural",
    "AZURE_VOICE_EN": "en-US-JennyNeural"
  }
}
